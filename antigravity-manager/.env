# CUSTOM
TZ=Asia/Shanghai
SERV_PORT=8045

# 容器内服务监听端口
PORT=8045

# [重要] 代理API密鑰。客户端（如Claude Code）访问时需提供的Key
ABV_API_KEY=sk-your-api-key

# [安全] Web管理后台登录密码。若不设置则回退使用API Key
ABV_WEB_PASSWORD=your-login-password

# [性能] 最大请求体限制 (Byte)。默认100MB，用于解决大图传输413错误
ABV_MAX_BODY_SIZE=104857600

# 日志等级 (debug, info, warn, error)
LOG_LEVEL=info

# 前端静态资源托管路径 (Dockerfile已内置)
ABV_DIST_PATH=/app/dist

# 用于远程OAuth回调的公网URL (可选)
ABV_PUBLIC_URL=
