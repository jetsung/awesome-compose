# CUSTOM
TZ=Asia/Shanghai
SERV_PORT=8000

# 建议映射宿主机端口到 8000
# HTTP_PORT=8000

# 进程设置
PUID=1000
PGID=1000

# Apprise 配置安全与模式
# 强烈推荐生产环境开启只读模式
APPRISE_CONFIG_LOCK=yes
# 禁用 Web 管理界面，仅作为 API 服务使用
APPRISE_API_ONLY=yes
# 显式禁用 Web 管理员后台功能
APPRISE_ADMIN=n
# STRICT_MODE=no

# 存储与状态
APPRISE_STATEFUL_MODE=simple
# APPRISE_CONFIG_DIR=/config
# APPRISE_STORAGE_DIR=/config/store

# 性能与限制
APPRISE_WORKER_COUNT=1
# APPRISE_CONFIG_MAX_LENGTH=512
# 附件大小设置 (单位: MB, 0 = 禁用)
APPRISE_ATTACH_SIZE=50

# 日志
LOG_LEVEL=INFO

# 安全
# ALLOWED_HOSTS=*
# SECRET_KEY=
