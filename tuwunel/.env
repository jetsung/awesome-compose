# CUSTOM
TZ=Asia/Shanghai
SERV_PORT=8008

# Tuwunel (Matrix homeserver) 常用环境变量配置文件
# 请根据实际需求修改，尤其是 TUWUNEL_SERVER_NAME 和 TUWUNEL_REGISTRATION_TOKEN

# === 必须修改的项 ===
TUWUNEL_SERVER_NAME=your.domain.name           # 必须修改，例如：matrix.example.com 或 tuwunel.chat
TUWUNEL_REGISTRATION_TOKEN=your_secure_token_here   # 强烈建议设置一个强随机令牌

# === 基础配置 ===
TUWUNEL_DATABASE_PATH=/var/lib/tuwunel
TUWUNEL_PORT=8008
TUWUNEL_ADDRESS=0.0.0.0
TUWUNEL_MAX_REQUEST_SIZE=20000000              # ≈20MB，单位：字节

# === 注册相关（根据需求选择其一） ===
TUWUNEL_ALLOW_REGISTRATION=true
# 如果想要完全开放注册（极不推荐，容易被滥用），可以取消下面这行的注释
# TUWUNEL_YES_I_AM_VERY_VERY_SURE_I_WANT_AN_OPEN_REGISTRATION_SERVER_PRONE_TO_ABUSE=true

# === 联邦相关 ===
TUWUNEL_ALLOW_FEDERATION=true
TUWUNEL_TRUSTED_SERVERS=["matrix.org"]

# === 日志级别（可选调整） ===
# TUWUNEL_LOG=info
# 更详细：TUWUNEL_LOG=debug
# 只显示警告及以上：TUWUNEL_LOG=warn
# 带特定模块过滤示例：TUWUNEL_LOG=warn,state_res=warn

# === 如果你使用了自定义配置文件映射（可选） ===
# TUWUNEL_CONFIG=/etc/tuwunel/tuwunel.toml

# === 其他常见但通常不需要修改的环境变量示例 ===
# TUWUNEL_NEW_USER_DISPLAYNAME_SUFFIX=💕
# TUWUNEL_ALLOW_GUEST_REGISTRATION=false
# TUWUNEL_TURN_URIS=["turn:turn.example.com:3478?transport=udp"]

# https://matrix-construct.github.io/tuwunel/deploying/root-domain-delegation.html?highlight=TUWUNEL_WELL_KNOWN__#configuration
TUWUNEL_WELL_KNOWN__SERVER=your.domain.name:443
TUWUNEL_WELL_KNOWN__CLIENT=https://your.domain.name
